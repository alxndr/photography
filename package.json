{
  "name": "abquine-photography",
  "version": "0.1.0-alpha",
  "private": true,
  "scripts": {
    "build": "hexo generate",
    "clean": "hexo clean",
    "deploy": "hexo deploy",
    "dev": "find . -not -name 'db.json' -not -path '*/node_modules/*' | entr -rs 'npm run serve'",
    "predev": "git submodule update --init --recursive",
    "serve": "hexo server --port 4001"
  },
  "hexo": {
    "version": "7.2.0"
  },
  "dependencies": {
    "hexo": "^7.0.0",
    "hexo-generator-archive": "^2.0.0",
    "hexo-generator-category": "^2.0.0",
    "hexo-generator-index": "^3.0.0",
    "hexo-generator-tag": "^2.0.0",
    "hexo-renderer-jade": "^0.5.0",
    "hexo-renderer-marked": "*",
    "hexo-renderer-stylus": "^3.0.0"
  },
  "devDependencies": {
    "hexo-server": "^3.0.0"
  }
}
